# Copy to .env.neon-verify (gitignored) — Neon console only, no Vercel yet.
#
# Neon → your project → Dashboard → Connection details:
#   - "Pooled connection"  → POSTGRES_PRISMA_URL (host contains -pooler)
#   - "Direct connection"  → POSTGRES_URL_NON_POOLING (no -pooler)
#
# Then: npm run db:verify-neon

POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
