# --- Postgres (Neon + Vercel) -------------------------------------------------
# Local Docker (matches docker-compose.yml): npm run db:up, then:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/stillwet_merch"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/stillwet_merch"
#
# Production (fresh Neon + Vercel project):
# 1. Vercel → Project → Storage → Connect Neon (or paste Neon connection strings in Environment Variables).
# 2. Set for Production (+ Preview if needed), then Redeploy:
#    POSTGRES_PRISMA_URL  — pooled URL (runtime; preferred by src/lib/env-postgres-url.ts)
#    POSTGRES_URL_NON_POOLING — direct / unpooled URL (migrations from laptop only)
#    Or use DATABASE_URL (pooled) + DIRECT_URL (direct) with the same values Neon shows in the dashboard.
# 3. Locally: npx vercel login && npx vercel link
#    npx vercel env pull .env.production.local --environment=production
#    npm run db:migrate:prod
#
# Do not commit real URLs. Placeholders below are for manual copy-paste into Vercel only:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Postgres direct (migrate from laptop) — Neon *unpooled* / direct only; never use for Vercel runtime.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require"
# POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Serverless: max connections per function instance (default 1 on Vercel, 10 local).
# PG_POOL_MAX="1"
# PG_CONNECTION_TIMEOUT_MS="15000"

# Google Merchant Center — automated product sync (Merchant API v1)
# Enable after MC API primary data source + GCP service account are configured.
# GOOGLE_MERCHANT_SYNC_ENABLED="1"
# GOOGLE_MERCHANT_ACCOUNT_ID=""
# GOOGLE_MERCHANT_DATASOURCE_ID=""
# GOOGLE_MERCHANT_FEED_LABEL="US"
# GOOGLE_MERCHANT_CONTENT_LANGUAGE="en"
# GOOGLE_MERCHANT_DEFAULT_PRODUCT_CATEGORY="Apparel & Accessories"
# Full service account JSON (single line or multiline in Vercel):
# GOOGLE_MERCHANT_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"…","private_key":"…","client_email":"…"}'

# Public base URL (production: https://stillwet.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Listing artwork v2: presigned direct-to-R2 upload + compose dialog (blanket/poster safe). Off by default.
# NEXT_PUBLIC_LISTING_ARTWORK_V2="1"
# Optional domme shop quote mailto
NEXT_PUBLIC_MERCH_QUOTE_EMAIL="you@example.com"

# Site gate password
SITE_ACCESS_PASSWORD="your-private-shop-password"
# Site gate cookie secret (32+ chars)
SITE_ACCESS_SECRET="notliveyet!"

# Stripe secret
STRIPE_SECRET_KEY="sk_test_..."
# Stripe webhook signing
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe publishable
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Beta: block buyer cart payment only (add-to-cart still works). Creator signup, listings, promotions, gifts unchanged.
# STOREFRONT_BUYER_CHECKOUT_DISABLED="1"

# Local demo without Stripe: mock listing-fee pay (and promotion pay only when Stripe keys are unset).
# Same as MOCK_CHECKOUT=1. Restart dev after changing.
# With STRIPE_SECRET_KEY + NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY set, promotions always use real card pay.
# DEMO_MODE="1"
# MOCK_CHECKOUT="1"
#
# Production/staging: enable **promotion** demo pay only (real listing fees / orders unchanged). Requires comma-separated
# storefront slugs in production (empty allowlist = demo promotion pay disabled even if this is 1).
# PROMOTION_DEMO_CHECKOUT="1"
# PROMOTION_DEMO_SHOP_SLUGS="your-test-shop-slug,another-shop"
# When 1 with `next dev` (NODE_ENV=development), creator dashboard Orders tab shows a button to insert a fake paid
# order (no Stripe). Never enabled in production builds. Server-only.
# SHOP_DEMO_PURCHASE_BUTTON="1"

# Marketplace: platform fee on merchandise (percent, default 10)
# MARKETPLACE_PLATFORM_FEE_PERCENT="10"
# Marketplace: Stripe Connect destination charges when shop has completed onboarding (set to 1 to enable)
# MARKETPLACE_STRIPE_CONNECT="0"
# Stripe Connect Express account country (ISO 3166-1 alpha-2) when creating new connected accounts
# STRIPE_CONNECT_ACCOUNT_COUNTRY="US"
# Public HTTPS origin for Stripe business website prefill (`business_profile.url`). Use when
# NEXT_PUBLIC_APP_URL is localhost — Stripe will not prefill localhost shop URLs.
# STRIPE_CONNECT_WEBSITE_ORIGIN="https://stillwet.com"
# Hot-items / featured-shop fallback slugs when env unset (comma-separated creator shop slugs)
# PLATFORM_HOT_ITEMS_FALLBACK_SHOP_SLUGS="stillwet,stillwet-merch"

# Printify API
PRINTIFY_API_TOKEN=""
# Printify shop id
PRINTIFY_SHOP_ID=""
# HMAC secret for Printify → /api/webhooks/printify (16+ chars; required in production)
PRINTIFY_WEBHOOK_SECRET=""
# Printify order shipping method id
PRINTIFY_SHIPPING_METHOD="1"
# Legacy; catalog sync assigns the built-in “no-tag” tag until you set type tags on each listing
PRINTIFY_IMPORT_TAG_SLUG="mug"
# sub | domme | both
PRINTIFY_IMPORT_AUDIENCE="both"

# Buyer merchandise shipping at checkout is free (no env knob).
# Optional estimated sales tax rate on merchandise (decimal, e.g. 0.0825 = 8.25%)
# Cart summary only — Stripe Tax at payment uses the buyer shipping address when enabled below.
ESTIMATED_SALES_TAX_RATE=""
# Stripe Tax on buyer checkout (default on). Requires Stripe Tax enabled in Dashboard.
# Set to 0 to disable automatic_tax on Checkout Sessions (e.g. before Tax is configured).
# STRIPE_CHECKOUT_AUTOMATIC_TAX="1"
# Pass Stripe Tax service cost inside the buyer-facing Payment Processing line (default on when automatic tax is on). 0.5% of subtotal + shipping + tip.
# STRIPE_TAX_BUYER_FEE="1"
# STRIPE_TAX_BUYER_FEE_RATE="0.005"

# iron-session (32+ chars)
SESSION_SECRET="replace-with-at-least-32-random-characters-!!"

# Local dev only (`npm run dev`, NODE_ENV=development): skip shop email 2FA on password login when `1` / `true` / `yes`.
# Never set in production — ignored when NODE_ENV=production.
# SHOP_LOCAL_2FA_BYPASS="1"

# Admin login
ADMIN_PASSWORD="change-me"

# Shop dashboard “forgot password” — Resend (https://resend.com)
# Required in production: API key from Resend → API Keys.
# RESEND_API_KEY="re_..."
# Optional From for automated admin digest (Backend → Email format → Admin digest). Falls back to CONTACT_QUOTE_FROM_EMAIL.
# ADMIN_SUMMARY_FROM_EMAIL="Still Wet Merch <noreply@auto.stillwet.com>"
# Optional: verified From (recommended for production). If unset, uses Resend’s
# onboarding@resend.dev (fine for testing; may only deliver to your own verified recipient).
# In Resend, verify the subdomain you send from (e.g. add domain "auto.stillwet.com" and its DNS).
# SHOP_PASSWORD_RESET_EMAIL_FROM="Still Wet Merch <noreply@auto.stillwet.com>"
# Optional: shop email verification (defaults to SHOP_PASSWORD_RESET_EMAIL_FROM). Do not use yourdomain.com placeholders.
# SHOP_EMAIL_VERIFICATION_EMAIL_FROM="Still Wet Merch <noreply@auto.stillwet.com>"
# Optional: gift-code emails (defaults to SHOP_PASSWORD_RESET_EMAIL_FROM).
# SHOP_GIFT_CODE_EMAIL_FROM="Still Wet Merch <noreply@auto.stillwet.com>"
# Optional: inactivity warning emails (defaults to SHOP_PASSWORD_RESET_EMAIL_FROM).
# SHOP_INACTIVITY_WARNING_EMAIL_FROM="Still Wet Merch <noreply@auto.stillwet.com>"
# Optional: From for “password / email changed” security notices (defaults to SHOP_PASSWORD_RESET_EMAIL_FROM).
# SHOP_PASSWORD_CHANGED_EMAIL_FROM="Still Wet Merch <noreply@auto.stillwet.com>"
# Optional: shown as a mailto “report unauthorized change” link inside those emails (dashboard Support link is always included).
# SHOP_SECURITY_ALERT_EMAIL="support@yourdomain.com"
# Reset links use NEXT_PUBLIC_APP_URL (or Vercel’s URL in production if unset).
# Optional: allow /dashboard/preview-reset-email on non-local (e.g. Vercel Preview only). Default off.
# ALLOW_EMAIL_PREVIEW="1"
#
# Resend inbound → Admin Dash → Inbox (`/admin?tab=admin-inbox`)
# 1) Enable Receiving for your domain in Resend; set MX so mail to info@… hits Resend.
# 2) Webhook URL: `https://<your-domain>/api/webhooks/resend-inbound` with event `email.received`.
# 3) Signing secret from Resend (starts with whsec_):
# RESEND_INBOUND_WEBHOOK_SECRET="whsec_..."
# (Or reuse RESEND_WEBHOOK_SECRET if you use one secret for that webhook only.)
# Optional: which address the app stores when it matches the To field (default info@stillwet.com):
# ADMIN_INBOX_EMAIL="info@stillwet.com"
# Optional: full Resend "From" for inbox tab replies (default "Still Wet <ADMIN_INBOX_EMAIL>"):
# ADMIN_INBOX_REPLY_FROM="Still Wet Merch <info@stillwet.com>"

# Cloudflare R2 (listing / shop image uploads — S3-compatible API)
# API token must allow Object Read & Write on the whole bucket (or at least both
# listing/ for admin catalog images and shops/ for creator listing artwork + avatars).
# R2_ACCOUNT_ID="abc…"   # or set R2_ENDPOINT to full https://… .r2.cloudflarestorage.com URL
# R2_ENDPOINT=""       # optional override; default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Bucket id — R2_BUCKET_NAME / R2_Bucket_name / any casing of those names also work
R2_BUCKET=""
# Public origin for objects, no trailing slash — must match how browsers fetch images.
# Quick start: enable R2.dev on the bucket → https://pub-xxxxx.r2.dev
# Production: custom domain after stillwet.com is on Cloudflare → https://cdn.stillwet.com
# Setup guide: docs/r2-stillwet-domain.md
R2_PUBLIC_BASE_URL="https://cdn.stillwet.com"
# Transactional email logo: `npm run r2:upload-site-email-logo` → site/still-wet-logo-2048.png on this CDN.
# Outbound emails use R2_PUBLIC_BASE_URL (not the app domain — avoids SITE_ACCESS_PASSWORD gate).
# Optional override: SITE_EMAIL_LOGO_URL="https://cdn.stillwet.com/site/still-wet-logo-2048.png"

# Printify sync: max bytes for stored primary image after compression (default 110 KiB = 112640)
# PRINTIFY_IMPORT_IMAGE_MAX_BYTES="112640"


